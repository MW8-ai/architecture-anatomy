      "children": [
        {"id":"hst_ts",   "l":"Time-Series DB",  "type":"volume","cls":"conf","addr":"OSIsoft PI"},
        {"id":"hst_tag",  "l":"Tag Dictionary",  "type":"service","cls":"conf","addr":"~50K tags"},
        {"id":"hst_rep",  "l":"Replication",     "type":"service","cls":"conf","addr":"async"},
        {"id":"hst_api",  "l":"REST API",         "type":"service","cls":"int", "addr":":8080"}
