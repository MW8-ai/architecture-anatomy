  },
  "layers": [
    {
      "id": "skel",
      "organ": "Osseous",
      "arch": "Field & Compute",
      "color": "var(--skeleton)",
      "blend": true,
      "flow": false,
      "edges": [
        { "a": "plc_a",     "b": "edge_gw",    "conn": "lan" },
        { "a": "plc_b",     "b": "edge_gw",    "conn": "lan" },
        { "a": "hmi",       "b": "plc_a",      "conn": "lan" },
        { "a": "hmi",       "b": "plc_b",      "conn": "lan" },
        { "a": "sensors",   "b": "proto_conv",  "conn": "lan" },
        { "a": "proto_conv","b": "edge_gw",     "conn": "lan" },
        { "a": "edge_gw",   "b": "edge_ts",     "conn": "lan" }
      ]
    },
    {
      "id": "vasc",
      "organ": "Vascular",
      "arch": "Network & Data Flow",
      "color": "var(--vascular)",
      "blend": true,
      "flow": true,
      "edges": [
        { "a": "edge_gw",   "b": "data_diode",  "proto": "Modbus/MQTT",  "conn": "lan"  },
        { "a": "proto_conv","b": "ot_fw",        "proto": "DNP3→MQTT",   "conn": "lan"  },
        { "a": "data_diode","b": "demil",        "proto": "UDP one-way",  "conn": "lan"  },
        { "a": "ot_fw",     "b": "demil",        "proto": "filtered TCP", "conn": "lan"  },
        { "a": "demil",     "b": "historian",    "proto": "OPC-UA",  "port": 4840, "conn": "lan" },
        { "a": "demil",     "b": "mqtt",         "proto": "MQTT",    "port": 1883, "conn": "lan" },
        { "a": "historian", "b": "data_lake",    "proto": "HTTPS",   "port": 443,  "conn": "lan" },
        { "a": "mqtt",      "b": "stream",       "proto": "Kafka",   "port": 9092, "conn": "lan" },
        { "a": "stream",    "b": "ml_pipe",      "proto": "gRPC",    "port": 8080, "conn": "lan" },
        { "a": "stream",    "b": "dashboard",    "proto": "WebSocket","port": 443, "conn": "lan" },
        { "a": "ml_pipe",   "b": "dashboard",    "proto": "HTTPS",   "port": 443,  "conn": "lan" }
      ]
    },
    {
      "id": "nerv",
      "organ": "Nervous",
      "arch": "Control & Monitoring",
      "color": "var(--nervous)",
      "blend": true,
      "flow": true,
      "edges": [
        { "a": "ot_soc",    "b": "ot_fw",       "proto": "SSH",    "port": 22,   "conn": "lan"      },
        { "a": "ot_soc",    "b": "historian",   "proto": "HTTPS",  "port": 443,  "conn": "lan"      },
        { "a": "ot_soc",    "b": "dashboard",   "proto": "HTTPS",  "port": 443,  "conn": "lan"      },
        { "a": "ot_soc",    "b": "ml_pipe",     "proto": "HTTPS",  "port": 443,  "conn": "lan"      }
      ]
    },
    {
      "id": "data",
      "organ": "Visceral",
      "arch": "Resilience & Archive",
      "color": "var(--lymph)",
      "blend": true,
      "flow": false,
      "edges": [
        { "a": "historian", "b": "immut_bak", "proto": "archive",  "conn": "repl", "rpo": "15min", "rto": "2hr"  },
        { "a": "data_lake", "b": "immut_bak", "proto": "snapshot", "conn": "repl", "rpo": "1hr",   "rto": "8hr"  },
        { "a": "edge_ts",   "b": "historian", "proto": "batch sync","conn": "repl", "rpo": "5min",  "rto": "30min"}
      ]
    }
  ],
  "flows": [
    {
      "id": "f1",
      "name": "Sensor data → Dashboard",
      "steps": ["sensors", "proto_conv", "edge_gw", "data_diode", "demil", "historian", "data_lake", "stream", "dashboard"],
      "note": "Full north-bound telemetry path. Data diode guarantees no return channel into OT — even a compromised IT system cannot reach field devices."
    },
    {
      "id": "f2",
      "name": "Alert → SOC triage",
      "steps": ["mqtt", "stream", "ot_soc"],
      "note": "Anomaly detected in stream processor; alert published to SOC. SOC can view historian and adjust firewall rules but cannot write to OT field."
    },
    {
      "id": "f3",
      "name": "ML predictive maintenance",
      "steps": ["historian", "data_lake", "stream", "ml_pipe", "dashboard"],
      "note": "Historical + live data trained against failure signatures. Model outputs anomaly scores surfaced on ops dashboard for maintenance scheduling."
    }
  ]
}
