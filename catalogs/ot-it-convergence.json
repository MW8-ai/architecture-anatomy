    },
    "data_diode": {
      "x": 190, "y": 307,
      "l": "Unidirectional GW",
      "zone": "OT/IT DMZ",
      "host": "hardware data diode",
      "cls": "int", "tier": 1, "eol": null, "icon": "network",
      "children": [
        {"id":"dd_rx",  "l":"RX (OT side)", "type":"zone","cls":"int",  "addr":"receive-only"},
        {"id":"dd_tx",  "l":"TX (IT side)", "type":"zone","cls":"conf", "addr":"transmit-only"},
        {"id":"dd_buf", "l":"Optical Buffer","type":"service","cls":"int","addr":"fiber link"},
        {"id":"dd_fmt", "l":"Protocol Strip","type":"service","cls":"int","addr":"UDP-only out"}
      ],
      "childEdges": [
        {"a":"dd_rx","b":"dd_buf","proto":"fiber in"},
        {"a":"dd_buf","b":"dd_tx","proto":"one-way"},
        {"a":"dd_buf","b":"dd_fmt","proto":"strip TCP"}
      ]
    },
    "ot_fw": {
      "x": 500, "y": 307,
