  "flows": [
    {
      "id": "f1",
      "name": "Remote access → Finance",
      "steps": [
        "rmt_usr",
        "ztna_px",
        "mfa_gw",
        "pam",
        "fin_sys",
        "db_core"
      ],
      "note": "All access authenticated at IdP, device-compliant, MFA-gated, brokered through PAM. No lateral movement possible — workloads never see raw credentials."
    },
    {
      "id": "f2",
      "name": "Identity chain: device → policy → access",
      "steps": [
        "intune",
        "ca_pol",
        "ztna_px",
        "corp_app"
      ],
      "note": "Conditional Access evaluates device health signal from Intune before issuing token to ZTNA proxy."
    },
    {
      "id": "f3",
      "name": "Incident: SOC triage",
      "steps": [
        "xdr",
        "siem",
        "ir_team"
      ],
