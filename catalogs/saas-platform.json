    "auth_svc": {
      "x": 140, "y": 308,
      "l": "Auth Service",
      "zone": "Application Services",
      "host": "container",
      "cls": "conf", "tier": 1, "eol": null, "icon": "identity"
    },
    "tenant_rt": {
      "x": 380, "y": 308,
      "l": "Tenant Router",
      "zone": "Application Services",
      "host": "container",
      "cls": "int", "tier": 1, "eol": null, "icon": "network"
    },
    "app_a": {
      "x": 610, "y": 308,
      "l": "App Service A",
