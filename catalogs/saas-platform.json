      "host": "managed gateway",
      "cls": "int", "tier": 1, "eol": null, "icon": "network",
      "children": [
        {"id":"gw_rt",   "l":"Route Table",    "type":"service","cls":"int"},
        {"id":"gw_auth", "l":"JWT Validator",  "type":"service","cls":"conf"},
        {"id":"gw_rl",   "l":"Rate Limiter",   "type":"service","cls":"int", "addr":"10K rps"},
