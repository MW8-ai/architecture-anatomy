  "layers": [
    {
      "id": "skel",
      "organ": "Osseous",
      "arch": "Hosting & Compute",
      "color": "var(--skeleton)",
      "blend": true,
      "flow": false,
      "edges": [
        { "a": "cdn",      "b": "lb",        "conn": "lan"  },
        { "a": "lb",       "b": "apigw",     "conn": "lan"  },
        { "a": "apigw",    "b": "auth_svc",  "conn": "lan"  },
        { "a": "apigw",    "b": "tenant_rt", "conn": "lan"  },
        { "a": "tenant_rt","b": "app_a",     "conn": "lan"  },
        { "a": "tenant_rt","b": "app_b",     "conn": "lan"  },
        { "a": "tenant_rt","b": "worker",    "conn": "lan"  },
        { "a": "worker",   "b": "mq",        "conn": "lan"  },
        { "a": "mq",       "b": "app_b",     "conn": "lan"  }
      ]
    },
    {
      "id": "vasc",
      "organ": "Vascular",
      "arch": "Network & Traffic",
      "color": "var(--vascular)",
      "blend": true,
      "flow": true,
      "edges": [
        { "a": "web_usr",  "b": "cdn",      "proto": "HTTPS",  "port": 443,  "conn": "internet" },
        { "a": "mob_app",  "b": "lb",       "proto": "HTTPS",  "port": 443,  "conn": "internet" },
        { "a": "api_int",  "b": "apigw",    "proto": "HTTPS",  "port": 443,  "conn": "internet" },
        { "a": "app_a",    "b": "pg_pri",   "proto": "pgsql",  "port": 5432, "conn": "lan"      },
        { "a": "app_b",    "b": "pg_pri",   "proto": "pgsql",  "port": 5432, "conn": "lan"      },
        { "a": "worker",   "b": "pg_pri",   "proto": "pgsql",  "port": 5432, "conn": "lan"      },
        { "a": "app_a",    "b": "pg_rep",   "proto": "pgsql",  "port": 5432, "conn": "lan"      },
        { "a": "app_a",    "b": "s3",       "proto": "HTTPS",  "port": 443,  "conn": "lan"      },
        { "a": "worker",   "b": "s3",       "proto": "HTTPS",  "port": 443,  "conn": "lan"      },
        { "a": "app_a",    "b": "email_gw", "proto": "HTTPS",  "port": 443,  "conn": "internet" },
        { "a": "obs",      "b": "app_a",    "proto": "scrape", "port": 9090, "conn": "lan"      },
        { "a": "obs",      "b": "app_b",    "proto": "scrape", "port": 9090, "conn": "lan"      },
        { "a": "obs",      "b": "pg_pri",   "proto": "scrape", "port": 9090, "conn": "lan"      }
      ]
    },
    {
      "id": "nerv",
      "organ": "Nervous",
      "arch": "Identity & Secrets",
      "color": "var(--nervous)",
      "blend": true,
      "flow": true,
      "hub": "auth_svc",
      "edges": [
        { "a": "auth_svc", "b": "secrets",   "proto": "mTLS",  "port": 443, "conn": "lan"      },
        { "a": "auth_svc", "b": "app_a",     "proto": "JWT",   "port": 443, "conn": "lan"      },
        { "a": "auth_svc", "b": "app_b",     "proto": "JWT",   "port": 443, "conn": "lan"      },
        { "a": "secrets",  "b": "app_a",     "proto": "mTLS",  "port": 443, "conn": "lan"      },
        { "a": "secrets",  "b": "worker",    "proto": "mTLS",  "port": 443, "conn": "lan"      },
        { "a": "secrets",  "b": "pg_pri",    "proto": "mTLS",  "port": 443, "conn": "lan"      }
      ]
    },
    {
      "id": "data",
      "organ": "Visceral",
      "arch": "Data & Resilience",
      "color": "var(--lymph)",
      "blend": true,
      "flow": false,
      "edges": [
        { "a": "pg_pri",  "b": "pg_rep",   "proto": "streaming repl", "conn": "repl", "rpo": "1min",  "rto": "2min"  },
        { "a": "pg_pri",  "b": "geo_rep",  "proto": "logical repl",   "conn": "repl", "rpo": "5min",  "rto": "30min" },
        { "a": "pg_pri",  "b": "bak_store","proto": "WAL archive",    "conn": "repl", "rpo": "1hr",   "rto": "4hr"   },
        { "a": "s3",      "b": "geo_rep",  "proto": "CRR",            "conn": "repl", "rpo": "15min", "rto": "1hr"   }
      ]
    }
  ],
  "flows": [
    {
      "id": "f1",
      "name": "Browser request → App",
      "steps": ["web_usr", "cdn", "lb", "apigw", "auth_svc", "tenant_rt", "app_a", "pg_pri"],
      "note": "Full north-south ingress: CDN terminates TLS, LB distributes, gateway authenticates JWT, tenant router shards by org_id, app writes to primary."
    },
    {
      "id": "f2",
      "name": "Async job pipeline",
      "steps": ["app_a", "worker", "mq", "app_b", "pg_pri"],
      "note": "App A enqueues work; worker dequeues and dispatches to App B; App B persists result. Decoupled so App A and App B scale independently."
    },
    {
      "id": "f3",
      "name": "Failover: primary → geo replica",
      "steps": ["pg_pri", "geo_rep"],
      "note": "5-minute RPO logical replication. On primary failure, promote geo_rep; update DNS; point app pools. RTO target 30 minutes."
    }
  ]
}
